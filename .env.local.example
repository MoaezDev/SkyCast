# =============================================================================
# SkyCast Environment Variables
# Copy this file to `.env.local` and fill in real values.
# =============================================================================

# WeatherAPI.com (https://www.weatherapi.com/) — Free tier: 1M calls/month.
# Sign up to obtain your API key.
WEATHER_API_KEY=your_weatherapi_key_here

# Public base URL of the WeatherAPI service. Override only if you proxy it.
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1

# Default location used when geolocation is denied or unavailable.
NEXT_PUBLIC_DEFAULT_LOCATION=London
